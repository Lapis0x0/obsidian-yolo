{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 80,
  "sortImports": true,
  "sortPackageJson": false,
  "ignorePatterns": [
    "main.js",
    "styles.css",
    "/node_modules",
    "logs",
    "*.log",
    "npm-debug.log*",
    "pnpm-debug.log*",
    "yarn-debug.log*",
    "yarn-error.log*",
    "lerna-debug.log*",
    ".DS_Store",
    ".env",
    ".env*.local",
    "/coverage",
    "/.nyc_output",
    "/.idea",
    ".project",
    ".classpath",
    ".c9/",
    "*.launch",
    ".settings/",
    "*.sublime-workspace",
    ".vscode/*",
    "!.vscode/settings.json",
    "!.vscode/tasks.json",
    "!.vscode/launch.json",
    "!.vscode/extensions.json",
    "esbuild.config.mjs",
    "jest.config.js",
    "version-bump.mjs",
    "versions.json",
    "package.json",
    "manifest.json",
    "src/database/migrations.json",
    ".obsidian",
    ".opencode",
    "Reference",
    "Design",
    "vendor",
    "runtime",
    "*.md"
  ]
}
